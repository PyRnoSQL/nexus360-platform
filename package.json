{
  "name": "nexus360",
  "version": "1.0.0",
  "private": true,
  "description": "NEXUS360 - DGSN Cameroon Operational Intelligence Platform",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "turbo start",
    "start:api": "pnpm --filter @nexus360/api start",
    "start:web": "pnpm --filter @nexus360/web start",
    "clean": "turbo clean && rm -rf node_modules",
    "deploy": "bash scripts/deploy.sh"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
