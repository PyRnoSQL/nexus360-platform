{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm install && pnpm build"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3,
    "healthcheckPath": "/health",
    "healthcheckTimeout": 300,
    "healthcheckInterval": 30
  },
  "services": [
    {
      "name": "api",
      "type": "web",
      "buildCommand": "pnpm build --filter=@nexus360/api",
      "startCommand": "pnpm start:api",
      "env": {
        "PORT": "3001",
        "NODE_ENV": "production"
      },
      "domains": ["api.nexus360.opex-analytica.com"]
    },
    {
      "name": "web",
      "type": "web",
      "buildCommand": "pnpm build --filter=@nexus360/web",
      "startCommand": "pnpm start:web",
      "env": {
        "PORT": "3000",
        "VITE_API_URL": "https://api.nexus360.opex-analytica.com"
      },
      "domains": ["nexus360.opex-analytica.com"]
    }
  ]
}
